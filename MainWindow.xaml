<Window x:Class="ObsidianDisk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ObsidianDisk.Controls"
        xmlns:views="clr-namespace:ObsidianDisk.Views"
        Title="{StaticResource App.WindowTitle}"
        Icon="Assets/app.ico"
        Height="820" Width="1320" MinHeight="560" MinWidth="900"
        Background="{DynamicResource Bg}"
        FontFamily="{StaticResource AppFont}"
        TextOptions.TextRenderingMode="Grayscale"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44" ResizeBorderThickness="6"
                      GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border x:Name="RootBorder" Background="{DynamicResource Bg}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>   <!-- barra de título -->
                <RowDefinition Height="Auto"/> <!-- progresso -->
                <RowDefinition Height="*"/>    <!-- conteúdo -->
                <RowDefinition Height="Auto"/> <!-- status -->
            </Grid.RowDefinitions>

            <!-- ===== Barra de título personalizada ===== -->
            <Border Grid.Row="0" Background="{DynamicResource Panel}"
                    BorderBrush="{DynamicResource Stroke}" BorderThickness="0,0,0,1">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="14,0,0,0"
                                VerticalAlignment="Center">
                        <Image Source="Assets/logo.png" Width="22" Height="22" VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="ObsidianDisk" Foreground="{DynamicResource Text}" FontSize="13.5"
                                       FontWeight="Bold"/>
                            <TextBlock Text="{StaticResource App.Subtitle}" Foreground="{DynamicResource Muted}"
                                       FontSize="10"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <controls:ObsidianButton x:Name="UpdateButton" Variant="Primary" Height="26"
                                Margin="0,0,10,0" Padding="10,3" FontSize="11.5" Visibility="Collapsed"
                                VerticalAlignment="Center" Click="Update_Click"/>
                        <Button Style="{StaticResource TitleBarButton}" Content="&#xE921;" Click="Minimize_Click"/>
                        <Button x:Name="MaximizeButton" Style="{StaticResource TitleBarButton}" Content="&#xE922;"
                                Click="Maximize_Click"/>
                        <Button Style="{StaticResource TitleBarCloseButton}" Content="&#xE8BB;" Click="Close_Click"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ===== Progresso global ===== -->
            <Border x:Name="ProgressPanel" Grid.Row="1" Background="{DynamicResource Panel}"
                    Padding="16,8" Visibility="Collapsed"
                    BorderBrush="{DynamicResource Stroke}" BorderThickness="0,0,0,1">
                <StackPanel>
                    <ProgressBar x:Name="ScanProgressBar" Style="{StaticResource SlimProgress}"
                                 IsIndeterminate="True" Maximum="100"/>
                    <DockPanel Margin="0,6,0,0" LastChildFill="False">
                        <TextBlock x:Name="ProgressText" DockPanel.Dock="Left" Foreground="{DynamicResource Muted}"
                                   FontSize="12" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="ProgressStats" DockPanel.Dock="Right" Foreground="{DynamicResource Text}"
                                   FontSize="12" FontWeight="SemiBold"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- ===== Conteúdo: sidebar + páginas ===== -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="208"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="{DynamicResource Panel}"
                        BorderBrush="{DynamicResource Stroke}" BorderThickness="0,0,1,0">
                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Top" Margin="0,10,0,0">
                            <RadioButton x:Name="NavOverview" Style="{StaticResource NavButton}" Tag="&#xE80F;"
                                         Content="{StaticResource Nav.Overview}" IsChecked="True" Checked="Nav_Checked"/>
                            <RadioButton x:Name="NavMap" Style="{StaticResource NavButton}" Tag="&#xE8A9;"
                                         Content="{StaticResource Nav.Map}" Checked="Nav_Checked"/>
                            <RadioButton x:Name="NavLargeFiles" Style="{StaticResource NavButton}" Tag="&#xE8A5;"
                                         Content="{StaticResource Nav.LargeFiles}" Checked="Nav_Checked"/>
                            <RadioButton x:Name="NavDuplicates" Style="{StaticResource NavButton}" Tag="&#xE8C8;"
                                         Content="{StaticResource Nav.Duplicates}" Checked="Nav_Checked"/>
                            <RadioButton x:Name="NavDiscoveries" Style="{StaticResource NavButton}" Tag="&#xEA80;"
                                         Content="{StaticResource Nav.Discoveries}" Checked="Nav_Checked"/>
                            <RadioButton x:Name="NavCleanup" Style="{StaticResource NavButton}" Tag="&#xEA99;"
                                         Content="{StaticResource Nav.Cleanup}" Checked="Nav_Checked"/>
                            <RadioButton x:Name="NavHistory" Style="{StaticResource NavButton}" Tag="&#xE81C;"
                                         Content="{StaticResource Nav.History}" Checked="Nav_Checked"/>
                            <RadioButton x:Name="NavSettings" Style="{StaticResource NavButton}" Tag="&#xE713;"
                                         Content="{StaticResource Nav.Settings}" Checked="Nav_Checked"/>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,14">
                            <controls:ObsidianButton x:Name="RescanButton" Variant="Ghost" Height="34"
                                    Click="Rescan_Click" Content="{StaticResource Shell.Rescan}" IsEnabled="False"/>
                            <TextBlock x:Name="LastScanText" Style="{StaticResource MutedText}" FontSize="11"
                                       Margin="2,8,0,0" Text="{StaticResource Shell.NoScanYet}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Páginas -->
                <Grid Grid.Column="1" Margin="14">
                    <views:OverviewPage x:Name="OverviewPage"/>
                    <views:MapPage x:Name="MapPage" Visibility="Collapsed"/>
                    <views:LargeFilesPage x:Name="LargeFilesPage" Visibility="Collapsed"/>
                    <views:DuplicatesPage x:Name="DuplicatesPage" Visibility="Collapsed"/>
                    <views:DiscoveriesPage x:Name="DiscoveriesPage" Visibility="Collapsed"/>
                    <views:CleanupPage x:Name="CleanupPage" Visibility="Collapsed"/>
                    <views:HistoryPage x:Name="HistoryPage" Visibility="Collapsed"/>
                    <views:SettingsPage x:Name="SettingsPage" Visibility="Collapsed"/>
                </Grid>
            </Grid>

            <!-- ===== Barra de status ===== -->
            <Border Grid.Row="3" Background="{DynamicResource Panel}" Padding="16,7"
                    BorderBrush="{DynamicResource Stroke}" BorderThickness="0,1,0,0">
                <DockPanel LastChildFill="True">
                    <TextBlock x:Name="VersionText" DockPanel.Dock="Right" Foreground="{DynamicResource Muted}"
                               FontSize="11" Opacity="0.7" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <controls:ObsidianButton x:Name="UndoButton" DockPanel.Dock="Right" Variant="Ghost"
                            Height="26" Padding="10,2" FontSize="11.5" Margin="16,0,0,0"
                            VerticalAlignment="Center" Visibility="Collapsed" Click="Undo_Click"
                            Content="{StaticResource Undo.Button}"/>
                    <TextBlock x:Name="StatusText" Foreground="{DynamicResource Muted}" FontSize="12"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                               Text="{StaticResource Shell.Ready}"/>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
