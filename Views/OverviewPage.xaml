<UserControl x:Class="ObsidianDisk.Views.OverviewPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
        <StackPanel>

            <!-- Card do disco -->
            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xEDA2;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                       Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="DiskTitle" Style="{StaticResource CardTitle}" Text="{StaticResource Ov.Disk}"/>
                                <TextBlock x:Name="DiskSubtitle" Style="{StaticResource MutedText}" Text="{StaticResource Ov.SelectDrive}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <ComboBox x:Name="DriveCombo" Style="{StaticResource DarkCombo}" Width="220" Height="36"
                                      SelectionChanged="DriveCombo_SelectionChanged"/>
                            <Button Style="{StaticResource GhostButton}" Height="36" Margin="8,0,0,0"
                                    Click="PickFolder_Click" Content="{StaticResource Ov.PickFolder}"/>
                            <Button x:Name="ScanButton" Style="{StaticResource PrimaryButton}" Height="36"
                                    Margin="8,0,0,0" Click="Scan_Click" Content="{StaticResource Ov.Scan}" MinWidth="120"/>
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="1" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <ProgressBar x:Name="UsageBar" Style="{StaticResource SlimProgress}" Height="8"
                                         Maximum="100" Value="0"/>
                            <DockPanel Margin="0,8,0,0" LastChildFill="False">
                                <TextBlock x:Name="UsageText" DockPanel.Dock="Left" Style="{StaticResource MutedText}"
                                           Text="—"/>
                                <TextBlock x:Name="FreeText" DockPanel.Dock="Right" Style="{StaticResource MutedText}"
                                           Text=""/>
                            </DockPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="PercentText" Foreground="{StaticResource Text}" FontSize="30"
                                       FontWeight="Bold" Text="—" HorizontalAlignment="Right"/>
                            <TextBlock Text="{StaticResource Ov.CurrentUse}" Style="{StaticResource MutedText}" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Mapa de Espaço (blocos semânticos) -->
            <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource CardTitle}" Text="{StaticResource Ov.MapCard}"/>
                        <TextBlock x:Name="BucketsHint" DockPanel.Dock="Right" Style="{StaticResource MutedText}"
                                   Text="{StaticResource Ov.ScanToCompute}"/>
                    </DockPanel>
                    <UniformGrid x:Name="BigBucketsGrid" Columns="3" Margin="0,12,0,0"/>
                    <UniformGrid x:Name="SmallBucketsGrid" Columns="3"/>
                    <TextBlock Style="{StaticResource MutedText}" FontSize="11" Margin="2,6,0,0"
                               Text="{StaticResource Ov.ClickBlock}"/>
                </StackPanel>
            </Border>

            <!-- Categorias -->
            <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource CardTitle}" Text="{StaticResource Ov.ByCategory}"/>
                        <TextBlock x:Name="CategoriesHint" DockPanel.Dock="Right" Style="{StaticResource MutedText}"
                                   Text="{StaticResource Ov.ScanToCompute}"/>
                    </DockPanel>
                    <UniformGrid x:Name="CategoryGrid" Columns="4" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <!-- Maiores pastas -->
            <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitle}" Text="{StaticResource Ov.TopFolders}"/>
                    <StackPanel x:Name="TopFoldersPanel" Margin="0,10,0,0"/>
                    <TextBlock x:Name="TopFoldersHint" Style="{StaticResource MutedText}"
                               Text="{StaticResource Ov.NoScan}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
