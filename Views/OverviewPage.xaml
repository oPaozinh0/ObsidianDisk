<UserControl x:Class="ObsidianDisk.Views.OverviewPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ObsidianDisk.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
        <StackPanel>

            <!-- Boas-vindas (some após o primeiro scan) -->
            <Border x:Name="WelcomeBanner" CornerRadius="12" Padding="20,16" Margin="0,0,0,12"
                    BorderThickness="1" BorderBrush="#887C5CFF">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#3D7C5CFF" Offset="0"/>
                        <GradientStop Color="#1A7C5CFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                        <TextBlock Text="{StaticResource Ov.WelcomeTitle}" Foreground="{DynamicResource Text}"
                                   FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="{StaticResource Ov.WelcomeText}" Style="{StaticResource MutedText}"
                                   Margin="0,4,0,0" TextWrapping="Wrap" MaxWidth="560" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <controls:ObsidianButton x:Name="WelcomeScanButton" DockPanel.Dock="Right" Variant="Primary"
                            Height="42" MinWidth="230" FontSize="14" VerticalAlignment="Center"
                            Click="Scan_Click"/>
                </DockPanel>
            </Border>

            <!-- Card do disco -->
            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xEDA2;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                       Foreground="{DynamicResource Accent}" VerticalAlignment="Center"/>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="DiskTitle" Style="{StaticResource CardTitle}" Text="{StaticResource Ov.Disk}"/>
                                <TextBlock x:Name="DiskSubtitle" Style="{StaticResource MutedText}" Text="{StaticResource Ov.SelectDrive}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <ComboBox x:Name="DriveCombo" Style="{StaticResource DarkCombo}" Width="220" Height="36"
                                      SelectionChanged="DriveCombo_SelectionChanged"/>
                            <controls:ObsidianButton Variant="Ghost" Height="36" Margin="8,0,0,0"
                                    Click="PickFolder_Click" Content="{StaticResource Ov.PickFolder}"/>
                            <controls:ObsidianButton x:Name="ScanButton" Variant="Primary" Height="36"
                                    Margin="8,0,0,0" Click="Scan_Click" Content="{StaticResource Ov.Scan}" MinWidth="120"/>
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="1" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <ProgressBar x:Name="UsageBar" Style="{StaticResource SlimProgress}" Height="8"
                                         Maximum="100" Value="0"/>
                            <DockPanel Margin="0,8,0,0" LastChildFill="False">
                                <TextBlock x:Name="UsageText" DockPanel.Dock="Left" Style="{StaticResource MutedText}"
                                           Text="—"/>
                                <TextBlock x:Name="FreeText" DockPanel.Dock="Right" Style="{StaticResource MutedText}"
                                           Text=""/>
                            </DockPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="PercentText" Foreground="{DynamicResource Text}" FontSize="30"
                                       FontWeight="Bold" Text="—" HorizontalAlignment="Right"/>
                            <TextBlock Text="{StaticResource Ov.CurrentUse}" Style="{StaticResource MutedText}" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Recomendações (após o scan) -->
            <Border x:Name="RecommendationsCard" Style="{StaticResource Card}" Margin="0,12,0,0"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitle}" Text="{StaticResource Ov.Recommendations}"/>
                    <UniformGrid Columns="3" Margin="0,12,0,0">

                        <Border Background="{DynamicResource Panel2}" CornerRadius="10" Padding="14,12"
                                Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="{StaticResource Ov.RecTempTitle}" Foreground="{DynamicResource Text}"
                                           FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock x:Name="RecTempText" Style="{StaticResource MutedText}" Margin="0,4,0,10"
                                           TextWrapping="Wrap" Text="{StaticResource Ov.RecTempMeasuring}"/>
                                <controls:ObsidianButton Variant="Ghost" Height="30" HorizontalAlignment="Left"
                                        Content="{StaticResource Ov.RecOpenCleanup}" Click="RecCleanup_Click"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource Panel2}" CornerRadius="10" Padding="14,12"
                                Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="{StaticResource Ov.RecLargeTitle}" Foreground="{DynamicResource Text}"
                                           FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock x:Name="RecLargeText" Style="{StaticResource MutedText}" Margin="0,4,0,10"
                                           TextWrapping="Wrap"/>
                                <controls:ObsidianButton Variant="Ghost" Height="30" HorizontalAlignment="Left"
                                        Content="{StaticResource Ov.RecSeeFiles}" Click="RecLarge_Click"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource Panel2}" CornerRadius="10" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="{StaticResource Ov.RecDupTitle}" Foreground="{DynamicResource Text}"
                                           FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,10" TextWrapping="Wrap"
                                           Text="{StaticResource Ov.RecDupValue}"/>
                                <controls:ObsidianButton Variant="Ghost" Height="30" HorizontalAlignment="Left"
                                        Content="{StaticResource Ov.RecFindDup}" Click="RecDup_Click"/>
                            </StackPanel>
                        </Border>

                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Mapa de Espaço (blocos semânticos) -->
            <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource CardTitle}" Text="{StaticResource Ov.MapCard}"/>
                        <TextBlock x:Name="BucketsHint" DockPanel.Dock="Right" Style="{StaticResource MutedText}"
                                   Text="{StaticResource Ov.ScanToCompute}"/>
                    </DockPanel>
                    <UniformGrid x:Name="BigBucketsGrid" Columns="3" Margin="0,12,0,0"/>
                    <UniformGrid x:Name="SmallBucketsGrid" Columns="3"/>
                    <TextBlock Style="{StaticResource MutedText}" FontSize="11" Margin="2,6,0,0"
                               Text="{StaticResource Ov.ClickBlock}"/>
                </StackPanel>
            </Border>

            <!-- Categorias -->
            <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource CardTitle}" Text="{StaticResource Ov.ByCategory}"/>
                        <TextBlock x:Name="CategoriesHint" DockPanel.Dock="Right" Style="{StaticResource MutedText}"
                                   Text="{StaticResource Ov.ScanToCompute}"/>
                    </DockPanel>
                    <UniformGrid x:Name="CategoryGrid" Columns="4" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <!-- Maiores pastas -->
            <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitle}" Text="{StaticResource Ov.TopFolders}"/>
                    <StackPanel x:Name="TopFoldersPanel" Margin="0,10,0,0"/>
                    <TextBlock x:Name="TopFoldersHint" Style="{StaticResource MutedText}"
                               Text="{StaticResource Ov.NoScan}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
