<UserControl x:Class="ObsidianDisk.Views.CleanupPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ObsidianDisk.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
        <StackPanel>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <!-- Botões declarados primeiro: reservam a largura antes do texto, que quebra no resto -->
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top"
                                    Margin="12,0,0,0">
                            <controls:ObsidianButton x:Name="ElevateButton" Variant="Ghost" Height="36"
                                    Margin="0,0,10,0" Click="Elevate_Click" Visibility="Collapsed"
                                    Content="{StaticResource Cl.Elevate}"/>
                            <controls:ObsidianButton x:Name="RefreshButton" Variant="Ghost" Height="36"
                                    Click="Refresh_Click" Content="{StaticResource Cl.Refresh}"/>
                            <controls:ObsidianButton x:Name="CleanButton" Variant="Primary" Height="36"
                                    Margin="10,0,0,0" MinWidth="180" Click="Clean_Click"
                                    Content="{StaticResource Cl.Clean}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Style="{StaticResource CardTitle}" Text="{StaticResource Cl.Title}"/>
                            <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,0" TextWrapping="Wrap"
                                       Text="{StaticResource Cl.Desc}"/>
                        </StackPanel>
                    </DockPanel>

                    <DockPanel Margin="0,14,0,0" LastChildFill="True">
                        <TextBlock Text="{StaticResource Cl.Profile}" Style="{StaticResource MutedText}"
                                   DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="ProfileCombo" Style="{StaticResource DarkCombo}" Width="200" Height="32"
                                  DockPanel.Dock="Left" SelectionChanged="Profile_Changed"/>
                        <TextBlock x:Name="ProfileHint" Style="{StaticResource MutedText}" FontSize="11.5"
                                   VerticalAlignment="Center" Margin="12,0,0,0" TextTrimming="CharacterEllipsis"/>
                    </DockPanel>

                    <CheckBox x:Name="DryRunCheck" Style="{StaticResource Switch}" Margin="0,12,0,0"
                              Content="{StaticResource Cl.DryRun}"/>

                    <StackPanel x:Name="ProgressRow" Margin="0,12,0,0" Visibility="Collapsed">
                        <ProgressBar Style="{StaticResource SlimProgress}" IsIndeterminate="True"/>
                        <TextBlock x:Name="ProgressLabel" Style="{StaticResource MutedText}" Margin="0,5,0,0"/>
                    </StackPanel>

                    <Border x:Name="ResultBanner" Background="#2A22C55E" BorderBrush="#8822C55E"
                            BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,12,0,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="ResultText" Foreground="{DynamicResource Text}" FontSize="12.5"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,12,0,0" Padding="10">
                <StackPanel x:Name="TargetsPanel"/>
            </Border>

            <TextBlock Style="{StaticResource MutedText}" FontSize="11" Margin="4,10,0,0" TextWrapping="Wrap"
                       Text="{StaticResource Cl.Tip}"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
