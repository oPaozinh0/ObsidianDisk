<UserControl x:Class="ObsidianDisk.Views.CleanupPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
        <StackPanel>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Style="{StaticResource CardTitle}" Text="Limpeza do Sistema"/>
                            <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,0" TextWrapping="Wrap"
                                       Text="Locais de arquivos temporários do Windows. Marque o que deseja limpar — itens em uso são pulados automaticamente."/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                            <Button x:Name="RefreshButton" Style="{StaticResource GhostButton}" Height="36"
                                    Click="Refresh_Click" Content="⟳  Atualizar tamanhos"/>
                            <Button x:Name="CleanButton" Style="{StaticResource PrimaryButton}" Height="36"
                                    Margin="10,0,0,0" MinWidth="180" Click="Clean_Click"
                                    Content="🧹  Limpar selecionados"/>
                        </StackPanel>
                    </DockPanel>

                    <StackPanel x:Name="ProgressRow" Margin="0,12,0,0" Visibility="Collapsed">
                        <ProgressBar Style="{StaticResource SlimProgress}" IsIndeterminate="True"/>
                        <TextBlock x:Name="ProgressLabel" Style="{StaticResource MutedText}" Margin="0,5,0,0"/>
                    </StackPanel>

                    <Border x:Name="ResultBanner" Background="#2A22C55E" BorderBrush="#8822C55E"
                            BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,12,0,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="ResultText" Foreground="{StaticResource Text}" FontSize="12.5"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,12,0,0" Padding="10">
                <StackPanel x:Name="TargetsPanel"/>
            </Border>

            <TextBlock Style="{StaticResource MutedText}" FontSize="11" Margin="4,10,0,0" TextWrapping="Wrap"
                       Text="Dica: alguns arquivos do Temp do Windows e do cache do Windows Update pertencem ao sistema e só podem ser removidos executando o app como administrador — eles são pulados e contados no resultado."/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
