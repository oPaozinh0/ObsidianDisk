<UserControl x:Class="ObsidianDisk.Views.QuarantinePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ObsidianDisk.Controls">
    <Border Style="{StaticResource Card}" Padding="16,12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="False">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <controls:ObsidianButton Variant="Primary" Height="32" Click="Restore_Click"
                            Content="{StaticResource Qt.Restore}"/>
                    <controls:ObsidianButton Variant="Ghost" Height="32" Margin="8,0,0,0" Click="Purge_Click"
                            Content="{StaticResource Qt.Purge}"/>
                    <controls:ObsidianButton Variant="Danger" Height="32" Margin="8,0,0,0" Click="EmptyAll_Click"
                            Content="{StaticResource Qt.EmptyAll}"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource CardTitle}" Text="{StaticResource Qt.Title}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="CountText" Style="{StaticResource MutedText}" Margin="12,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>

            <TextBlock x:Name="DescText" Grid.Row="1" Style="{StaticResource MutedText}" TextWrapping="Wrap"
                       Margin="0,8,0,10"/>

            <ListView x:Name="ResultsList" Grid.Row="2" Style="{StaticResource DarkListView}"
                      SelectionMode="Extended">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="{StaticResource Qt.ColName}" Width="240">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" FontSize="13"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{StaticResource Qt.ColOrigin}" Width="360">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding OriginalPath}" TextTrimming="CharacterEllipsis"
                                               FontSize="12" Foreground="{DynamicResource Muted}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{StaticResource Qt.ColDeleted}" Width="120">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DeletedText}" FontSize="12"
                                               Foreground="{DynamicResource Muted}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{StaticResource Qt.ColRemaining}" Width="120">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RemainingText}" FontSize="12"
                                               Foreground="{DynamicResource Muted}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{StaticResource Dc.ColSize}" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SizeText}" FontSize="13" FontWeight="SemiBold"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Border>
</UserControl>
