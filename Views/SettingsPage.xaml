<UserControl x:Class="ObsidianDisk.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ObsidianDisk.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="640" HorizontalAlignment="Left">

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitle}" Text="{StaticResource St.Interface}"/>
                    <DockPanel Margin="0,14,0,0" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Foreground="{DynamicResource Text}" FontSize="13"
                                   Text="{StaticResource St.Language}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="LanguageCombo" DockPanel.Dock="Right" Style="{StaticResource DarkCombo}"
                                  Width="240" Height="32" SelectionChanged="Interface_Changed"/>
                    </DockPanel>
                    <DockPanel Margin="0,10,0,0" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Foreground="{DynamicResource Text}" FontSize="13"
                                   Text="{StaticResource St.Theme}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="ThemeCombo" DockPanel.Dock="Right" Style="{StaticResource DarkCombo}"
                                  Width="240" Height="32" SelectionChanged="Interface_Changed"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitle}" Text="{StaticResource St.Deletion}"/>
                    <CheckBox x:Name="ConfirmDeleteSwitch" Style="{StaticResource Switch}" Margin="0,14,0,0"
                              Content="{StaticResource St.ConfirmDelete}" Checked="Setting_Changed"
                              Unchecked="Setting_Changed"/>
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,6,0,0" TextWrapping="Wrap"
                               Text="{StaticResource St.PermanentNote}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitle}" Text="{StaticResource St.Analysis}"/>
                    <DockPanel Margin="0,14,0,0" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Foreground="{DynamicResource Text}" FontSize="13"
                                   Text="{StaticResource St.MinSize}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="MinSizeCombo" DockPanel.Dock="Right" Style="{StaticResource DarkCombo}"
                                  Width="140" Height="32" SelectionChanged="Setting_Changed"/>
                    </DockPanel>
                    <CheckBox x:Name="LiveMonitoringSwitch" Style="{StaticResource Switch}" Margin="0,14,0,0"
                              Content="{StaticResource St.LiveMonitor}" Checked="Setting_Changed"
                              Unchecked="Setting_Changed"/>
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,6,0,0" TextWrapping="Wrap"
                               Text="{StaticResource St.LiveMonitorNote}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitle}" Text="{StaticResource St.Support}"/>
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,8,0,0" TextWrapping="Wrap"
                               Text="{StaticResource St.SupportText}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <controls:ObsidianButton Variant="Primary" Height="34"
                                Content="{StaticResource St.BuyCoffee}" Click="BuyCoffee_Click"/>
                        <controls:ObsidianButton Variant="Ghost" Height="34" Margin="10,0,0,0"
                                Content="{StaticResource St.GitHub}" Click="GitHub_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitle}" Text="{StaticResource St.About}"/>
                    <TextBlock x:Name="VersionText" Foreground="{DynamicResource Text}" FontSize="13" Margin="0,10,0,0"
                               Text="ObsidianDisk"/>
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,0" TextWrapping="Wrap"
                               Text="{StaticResource St.AboutText}"/>
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,8,0,0"
                               Text="{StaticResource St.TechLine}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
