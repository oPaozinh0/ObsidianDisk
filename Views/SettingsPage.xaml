<UserControl x:Class="ObsidianDisk.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="640" HorizontalAlignment="Left">

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitle}" Text="Exclusão"/>
                    <CheckBox x:Name="ConfirmDeleteSwitch" Style="{StaticResource Switch}" Margin="0,14,0,0"
                              Content="Confirmar antes de enviar para a Lixeira" Checked="Setting_Changed"
                              Unchecked="Setting_Changed"/>
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,6,0,0" TextWrapping="Wrap"
                               Text="A exclusão permanente sempre pede confirmação, independentemente desta opção."/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitle}" Text="Análise"/>
                    <DockPanel Margin="0,14,0,0" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Foreground="{StaticResource Text}" FontSize="13"
                                   Text="Tamanho mínimo para Arquivos Grandes" VerticalAlignment="Center"/>
                        <ComboBox x:Name="MinSizeCombo" DockPanel.Dock="Right" Style="{StaticResource DarkCombo}"
                                  Width="140" Height="32" SelectionChanged="Setting_Changed"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitle}" Text="Sobre"/>
                    <TextBlock Foreground="{StaticResource Text}" FontSize="13" Margin="0,10,0,0"
                               Text="ObsidianDisk 1.0"/>
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,0" TextWrapping="Wrap"
                               Text="Analisador visual de espaço em disco. Escaneie uma unidade, explore o mapa de espaço, encontre os maiores arquivos e libere espaço sem sair do aplicativo."/>
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,8,0,0"
                               Text="Feito em .NET 8 + WPF · Treemap squarified com renderização ao vivo"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
