<UserControl x:Class="ObsidianDisk.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ObsidianDisk.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
        <!-- Bento grid: mosaico de cards preenchendo a largura -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,12">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitle}" Text="{StaticResource St.Interface}"/>
                    <TextBlock Foreground="{DynamicResource Text}" FontSize="13" Margin="0,14,0,6"
                               Text="{StaticResource St.Language}"/>
                    <ComboBox x:Name="LanguageCombo" Style="{StaticResource DarkCombo}" Height="32"
                              SelectionChanged="Interface_Changed"/>
                    <TextBlock Foreground="{DynamicResource Text}" FontSize="13" Margin="0,12,0,6"
                               Text="{StaticResource St.Theme}"/>
                    <ComboBox x:Name="ThemeCombo" Style="{StaticResource DarkCombo}" Height="32"
                              SelectionChanged="Interface_Changed"/>
                    <CheckBox x:Name="ColorBlindSwitch" Style="{StaticResource Switch}" Margin="0,14,0,0"
                              Content="{StaticResource St.ColorBlind}" Checked="Interface_Changed"
                              Unchecked="Interface_Changed"/>
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,6,0,0" TextWrapping="Wrap"
                               Text="{StaticResource St.ColorBlindNote}"/>
                    <CheckBox x:Name="SoftwareRenderSwitch" Style="{StaticResource Switch}" Margin="0,14,0,0"
                              Content="{StaticResource St.SoftwareRender}" Checked="Interface_Changed"
                              Unchecked="Interface_Changed"/>
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,6,0,0" TextWrapping="Wrap"
                               Text="{StaticResource St.SoftwareRenderNote}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,12,12">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitle}" Text="{StaticResource St.Deletion}"/>
                    <CheckBox x:Name="ConfirmDeleteSwitch" Style="{StaticResource Switch}" Margin="0,14,0,0"
                              Content="{StaticResource St.ConfirmDelete}" Checked="Setting_Changed"
                              Unchecked="Setting_Changed"/>
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,6,0,0" TextWrapping="Wrap"
                               Text="{StaticResource St.PermanentNote}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitle}" Text="{StaticResource St.Analysis}"/>
                    <TextBlock Foreground="{DynamicResource Text}" FontSize="13" Margin="0,14,0,6"
                               Text="{StaticResource St.MinSize}"/>
                    <ComboBox x:Name="MinSizeCombo" Style="{StaticResource DarkCombo}" Height="32"
                              SelectionChanged="Setting_Changed"/>
                    <CheckBox x:Name="LiveMonitoringSwitch" Style="{StaticResource Switch}" Margin="0,14,0,0"
                              Content="{StaticResource St.LiveMonitor}" Checked="Setting_Changed"
                              Unchecked="Setting_Changed"/>
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,6,0,0" TextWrapping="Wrap"
                               Text="{StaticResource St.LiveMonitorNote}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitle}" Text="{StaticResource St.Support}"/>
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,8,0,0" TextWrapping="Wrap"
                               Text="{StaticResource St.SupportText}"/>
                    <WrapPanel Margin="0,12,0,0">
                        <controls:ObsidianButton Variant="Primary" Height="34" Margin="0,0,8,8"
                                Content="{StaticResource St.BuyCoffee}" Click="BuyCoffee_Click"/>
                        <controls:ObsidianButton Variant="Primary" Height="34" Margin="0,0,8,8"
                                Content="{StaticResource St.LivePix}" Click="LivePix_Click"/>
                        <controls:ObsidianButton Variant="Ghost" Height="34" Margin="0,0,0,8"
                                Content="{StaticResource St.GitHub}" Click="GitHub_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Style="{StaticResource Card}" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitle}" Text="{StaticResource St.About}"/>
                    <TextBlock x:Name="VersionText" Foreground="{DynamicResource Text}" FontSize="13" Margin="0,10,0,0"
                               Text="ObsidianDisk"/>
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,0" TextWrapping="Wrap"
                               Text="{StaticResource St.AboutText}"/>
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,8,0,0"
                               Text="{StaticResource St.TechLine}"/>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>
