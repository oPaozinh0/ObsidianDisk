<UserControl x:Class="ObsidianDisk.Views.LargeFilesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource Card}" Padding="16,12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,10">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource CardTitle}" Text="{StaticResource Lf.Title}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="MinSizeCombo" Style="{StaticResource DarkCombo}" Width="140" Height="32"
                              Margin="16,0,0,0" SelectionChanged="MinSize_Changed"/>
                    <TextBlock x:Name="CountText" Style="{StaticResource MutedText}" Margin="12,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock x:Name="CheckedText" Style="{StaticResource MutedText}" Margin="0,0,12,0"
                               VerticalAlignment="Center"/>
                    <Button Style="{StaticResource GhostButton}" Height="32" Click="Open_Click"
                            Content="{StaticResource Lf.Open}"/>
                    <Button Style="{StaticResource GhostButton}" Height="32" Margin="8,0,0,0" Click="DeleteRecycle_Click"
                            Content="{StaticResource Lf.Recycle}"/>
                    <Button x:Name="DeletePermanentButton" Style="{StaticResource GhostButton}" Height="32"
                            Margin="8,0,0,0" Click="DeletePermanent_Click" Foreground="#E06C75"
                            Content="{StaticResource Lf.Permanent}"/>
                </StackPanel>
            </DockPanel>

            <ListView x:Name="FilesList" Grid.Row="1" Style="{StaticResource DarkListView}"
                      SelectionMode="Extended">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="40">
                            <GridViewColumn.Header>
                                <CheckBox x:Name="SelectAllCheck" Style="{StaticResource DarkCheck}"
                                          Click="SelectAll_Click"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox Style="{StaticResource DarkCheck}"
                                              IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Click="RowCheck_Click"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{StaticResource Lf.ColCategory}" Width="130">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="9" Height="9" CornerRadius="4.5"
                                                Background="{Binding CategoryBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding CategoryLabel}" Margin="7,0,0,0" FontSize="12"
                                                   Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{StaticResource Lf.ColName}" Width="320">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" FontSize="13"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{StaticResource Lf.ColFolder}" Width="380">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Directory}" TextTrimming="CharacterEllipsis"
                                               FontSize="12" Foreground="{StaticResource Muted}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{StaticResource Lf.ColSize}" Width="110">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SizeText}" FontSize="13" FontWeight="SemiBold"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Border>
</UserControl>
