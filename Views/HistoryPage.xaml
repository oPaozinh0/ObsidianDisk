<UserControl x:Class="ObsidianDisk.Views.HistoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ObsidianDisk.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
        <StackPanel>

            <!-- Gráfico -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource CardTitle}"
                                   Text="{StaticResource Hi.Title}" VerticalAlignment="Center"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <controls:ObsidianButton Variant="Ghost" Height="32" Click="Export_Click"
                                    Content="{StaticResource Hi.Export}"/>
                            <ComboBox x:Name="PathCombo" Style="{StaticResource DarkCombo}"
                                      Width="260" Height="32" Margin="10,0,0,0"
                                      SelectionChanged="PathCombo_Changed"/>
                        </StackPanel>
                    </DockPanel>
                    <Canvas x:Name="ChartCanvas" Height="190" Margin="0,14,0,0" ClipToBounds="True"
                            SizeChanged="Chart_SizeChanged"/>
                    <TextBlock x:Name="ChartHint" Style="{StaticResource MutedText}" Margin="0,8,0,0"
                               Text="{StaticResource Hi.ChartHint}"/>
                </StackPanel>
            </Border>

            <!-- Estatísticas -->
            <UniformGrid x:Name="StatsGrid" Columns="3" Margin="0,12,0,0"/>

            <!-- Tendência e projeção -->
            <Border x:Name="TrendCard" Style="{StaticResource Card}" Margin="0,2,0,0"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitle}" Text="{StaticResource Hi.TrendTitle}"/>
                    <UniformGrid Columns="3" Margin="0,12,0,0">
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="{StaticResource Hi.Growth30}" Style="{StaticResource MutedText}"/>
                            <TextBlock x:Name="Growth30Text" Foreground="{DynamicResource Text}" FontSize="20"
                                       FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="{StaticResource Hi.Projection}" Style="{StaticResource MutedText}"/>
                            <TextBlock x:Name="ProjectionText" Foreground="{DynamicResource Text}" FontSize="20"
                                       FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{StaticResource Hi.FreeNow}" Style="{StaticResource MutedText}"/>
                            <TextBlock x:Name="FreeNowText" Foreground="{DynamicResource Text}" FontSize="20"
                                       FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </UniformGrid>
                    <Border x:Name="CapacityWarning" Background="#2AE0762F" BorderBrush="#88E0762F"
                            BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,12,0,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="CapacityWarningText" Foreground="{DynamicResource Text}"
                                   FontSize="12.5" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- O que mudou (diff entre os dois últimos snapshots) -->
            <Border x:Name="DiffCard" Style="{StaticResource Card}" Margin="0,12,0,0" Padding="16,12"
                    Visibility="Collapsed">
                <StackPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,8">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource CardTitle}"
                                   Text="{StaticResource Hi.DiffTitle}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="DiffSubtitle" DockPanel.Dock="Right" Style="{StaticResource MutedText}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                    <Border x:Name="ExplainerBanner" Background="{DynamicResource Panel2}" CornerRadius="8"
                            Padding="12,10" Margin="0,0,0,10" Visibility="Collapsed">
                        <TextBlock x:Name="ExplainerText" Foreground="{DynamicResource Text}" FontSize="13"
                                   TextWrapping="Wrap" LineHeight="19"/>
                    </Border>
                    <ListView x:Name="DiffList" Style="{StaticResource DarkListView}" SelectionMode="Single"
                              MaxHeight="280">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="{StaticResource Dc.ColName}" Width="240">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontSize="13"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{StaticResource Dc.ColDetail}" Width="360">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Path}" FontSize="12"
                                                       Foreground="{DynamicResource Muted}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{StaticResource Hi.ColChange}" Width="130">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DeltaText}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{Binding DeltaBrush}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- Tabela -->
            <Border Style="{StaticResource Card}" Margin="0,12,0,0" Padding="16,12">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitle}" Text="{StaticResource Hi.Records}" Margin="0,0,0,8"/>
                    <ListView x:Name="HistoryList" Style="{StaticResource DarkListView}" SelectionMode="Single"
                              MaxHeight="320">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="{StaticResource Hi.ColDate}" Width="170">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DateText}" FontSize="13"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{StaticResource Hi.ColPath}" Width="360">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Path}" FontSize="12" Foreground="{DynamicResource Muted}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{StaticResource Hi.ColFiles}" Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FilesText}" FontSize="13"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{StaticResource Hi.ColTotal}" Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SizeText}" FontSize="13" FontWeight="SemiBold"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{StaticResource Hi.ColChange}" Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DeltaText}" FontSize="13" Foreground="{Binding DeltaBrush}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
