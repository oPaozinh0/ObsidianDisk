<UserControl x:Class="ObsidianDisk.Views.DiscoveriesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ObsidianDisk.Controls">
    <Border Style="{StaticResource Card}" Padding="16,12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Botões declarados primeiro: reservam a largura antes do conteúdo à esquerda -->
            <DockPanel Grid.Row="0" LastChildFill="False">
                <StackPanel x:Name="ActionPanel" DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock x:Name="CheckedText" Style="{StaticResource MutedText}" Margin="0,0,12,0"
                               VerticalAlignment="Center"/>
                    <controls:ObsidianButton Variant="Ghost" Height="32" Click="Open_Click"
                            Content="{StaticResource Lf.Open}"/>
                    <controls:ObsidianButton Variant="Ghost" Height="32" Margin="8,0,0,0" Click="DeleteRecycle_Click"
                            Content="{StaticResource Lf.Recycle}"/>
                    <controls:ObsidianButton x:Name="DeletePermanentButton" Variant="Danger" Height="32"
                            Margin="8,0,0,0" Click="DeletePermanent_Click"
                            Content="{StaticResource Lf.Permanent}"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource CardTitle}" Text="{StaticResource Dc.Title}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="ModeCombo" Style="{StaticResource DarkCombo}" Width="230" Height="32"
                              Margin="16,0,0,0" SelectionChanged="Mode_Changed"/>
                    <TextBlock x:Name="CountText" Style="{StaticResource MutedText}" Margin="12,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>

            <TextBlock x:Name="DescText" Grid.Row="1" Style="{StaticResource MutedText}" TextWrapping="Wrap"
                       Margin="0,8,0,10"/>

            <ListView x:Name="ResultsList" Grid.Row="2" Style="{StaticResource DarkListView}"
                      SelectionMode="Extended">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="40">
                            <GridViewColumn.Header>
                                <CheckBox x:Name="SelectAllCheck" Style="{StaticResource DarkCheck}"
                                          Click="SelectAll_Click"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox Style="{StaticResource DarkCheck}"
                                              IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Click="RowCheck_Click"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{StaticResource Dc.ColName}" Width="300">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" FontSize="13"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{StaticResource Dc.ColDetail}" Width="420">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Detail}" TextTrimming="CharacterEllipsis"
                                               FontSize="12" Foreground="{DynamicResource Muted}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{StaticResource Dc.ColWhen}" Width="120">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding WhenText}" FontSize="12"
                                               Foreground="{DynamicResource Muted}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{StaticResource Dc.ColSize}" Width="110">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SizeText}" FontSize="13" FontWeight="SemiBold"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Border>
</UserControl>
