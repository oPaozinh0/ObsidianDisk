<UserControl x:Class="ObsidianDisk.Views.DuplicatesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ObsidianDisk.Controls">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="16,12">
            <StackPanel>
                <!-- Botões declarados primeiro: reservam a largura antes do conteúdo à esquerda -->
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <controls:ObsidianButton Variant="Ghost" Height="32" Click="DeleteRecycle_Click"
                                Content="{StaticResource Dup.DelRecycle}"/>
                        <controls:ObsidianButton Variant="Danger" Height="32" Margin="8,0,0,0"
                                Click="DeletePermanent_Click"
                                Content="{StaticResource Dup.DelPermanent}"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource CardTitle}" Text="{StaticResource Dup.Title}"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="MinSizeCombo" Style="{StaticResource DarkCombo}" Width="130" Height="32"
                                  Margin="16,0,0,0"/>
                        <controls:ObsidianButton x:Name="SearchButton" Variant="Primary" Height="32"
                                Margin="12,0,0,0" Click="Search_Click" Content="{StaticResource Dup.Search}"/>
                    </StackPanel>
                </DockPanel>

                <StackPanel x:Name="ProgressRow" Margin="0,10,0,0" Visibility="Collapsed">
                    <ProgressBar x:Name="SearchProgress" Style="{StaticResource SlimProgress}" Maximum="100"/>
                    <TextBlock x:Name="ProgressLabel" Style="{StaticResource MutedText}" Margin="0,5,0,0"/>
                </StackPanel>

                <TextBlock x:Name="SummaryText" Style="{StaticResource MutedText}" Margin="0,8,0,0"
                           Text="{StaticResource Dup.InitialHint}"/>
            </StackPanel>
        </Border>

        <!-- Grupos -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
            <StackPanel x:Name="GroupsPanel"/>
        </ScrollViewer>
    </Grid>
</UserControl>
