<UserControl x:Class="ObsidianDisk.Views.DuplicatesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="16,12">
            <StackPanel>
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource CardTitle}" Text="Arquivos Duplicados"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="MinSizeCombo" Style="{StaticResource DarkCombo}" Width="130" Height="32"
                                  Margin="16,0,0,0"/>
                        <Button x:Name="SearchButton" Style="{StaticResource PrimaryButton}" Height="32"
                                Margin="12,0,0,0" Click="Search_Click" Content="🔍  Procurar duplicados"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource GhostButton}" Height="32" Click="DeleteRecycle_Click"
                                Content="🗑  Excluir marcados (Lixeira)"/>
                        <Button Style="{StaticResource GhostButton}" Height="32" Margin="8,0,0,0"
                                Click="DeletePermanent_Click" Foreground="#E06C75"
                                Content="⚠  Excluir marcados (permanente)"/>
                    </StackPanel>
                </DockPanel>

                <StackPanel x:Name="ProgressRow" Margin="0,10,0,0" Visibility="Collapsed">
                    <ProgressBar x:Name="SearchProgress" Style="{StaticResource SlimProgress}" Maximum="100"/>
                    <TextBlock x:Name="ProgressLabel" Style="{StaticResource MutedText}" Margin="0,5,0,0"/>
                </StackPanel>

                <TextBlock x:Name="SummaryText" Style="{StaticResource MutedText}" Margin="0,8,0,0"
                           Text="Escaneie um disco e clique em Procurar. Em cada grupo, a cópia mais recente vem desmarcada (será mantida) — revise antes de excluir."/>
            </StackPanel>
        </Border>

        <!-- Grupos -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
            <StackPanel x:Name="GroupsPanel"/>
        </ScrollViewer>
    </Grid>
</UserControl>
