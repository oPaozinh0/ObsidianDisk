<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Tema claro "Quartzo" -->
    <Color x:Key="BgColor">#F2F3F7</Color>
    <Color x:Key="PanelColor">#FFFFFF</Color>
    <Color x:Key="Panel2Color">#E9EBF2</Color>
    <Color x:Key="StrokeColor">#D5D9E4</Color>
    <Color x:Key="AccentColor">#6C4CF0</Color>
    <Color x:Key="AccentHoverColor">#5A3BD6</Color>
    <Color x:Key="TextColor">#1B2130</Color>
    <Color x:Key="MutedColor">#5C6577</Color>

    <SolidColorBrush x:Key="Bg" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="Panel" Color="{StaticResource PanelColor}"/>
    <SolidColorBrush x:Key="Panel2" Color="{StaticResource Panel2Color}"/>
    <SolidColorBrush x:Key="Stroke" Color="{StaticResource StrokeColor}"/>
    <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHover" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="Text" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="Muted" Color="{StaticResource MutedColor}"/>

    <!-- Estados de interação -->
    <SolidColorBrush x:Key="HoverBg" Color="#DFE3EE"/>
    <SolidColorBrush x:Key="RowHover" Color="#ECEEF5"/>
    <SolidColorBrush x:Key="SelectedBg" Color="#E4DFF7"/>
    <SolidColorBrush x:Key="MenuHover" Color="#E4E7F2"/>
    <SolidColorBrush x:Key="ScrollThumb" Color="#C3C9DA"/>
    <SolidColorBrush x:Key="ScrollThumbHover" Color="#A7AFC8"/>
    <SolidColorBrush x:Key="TipBg" Color="#F0FFFFFF"/>

</ResourceDictionary>
